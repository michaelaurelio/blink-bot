        File file = SPIFFS.open("/custom_blink1.bin", "r");
        custom_blink1_buffer = (unsigned char*)malloc(file.size());
        file.read(custom_blink1_buffer, file.size());
        customBlinkFrames[0] = custom_blink1_buffer;
        file.close();
    }

    if (SPIFFS.exists("/custom_blink2.bin")) {
        File file = SPIFFS.open("/custom_blink2.bin", "r");
        custom_blink2_buffer = (unsigned char*)malloc(file.size());
        file.read(custom_blink2_buffer, file.size());
        customBlinkFrames[1] = custom_blink2_buffer;
        file.close();
    }
}

