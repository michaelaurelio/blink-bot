// ----- BLE CALLBACKS -----

class ServerCallbacks : public BLEServerCallbacks {
    void onConnect(BLEServer *pServer) {
        deviceConnected = true;
        Serial.println("[+] Bluetooth Connected!");
    }

    void onDisconnect(BLEServer *pServer) {
        deviceConnected = false;
        Serial.println("[-] Bluetooth Disconnected!");
        // Restart advertising if Bluetooth is still enabled
        if (bluetoothEnabled) {
            pServer->getAdvertising()->start();
            Serial.println("Restarting advertising...");
        }
    }
};

class AppStateCallbacks : public BLECharacteristicCallbacks {
    void onWrite(BLECharacteristic *pCharacteristic) {
        if (!focusModeEnabled) return; // Do nothing if focus mode is off

        String value = pCharacteristic->getValue();
        Serial.print("App State Received: ");
        Serial.println(value);

        if (value == "1") {
            Serial.println("Mobile app is open.");
            currentAnimationState = ANIM_IDLE;
            // Force the display to the home screen to show the new face
            showHome = true;
            showMenu = showTimer = showStopwatch = showPomodoro = showSettings = showInfo = showBluetoothSettings = false;
            resetFaceAnimation();
        } else {
            Serial.println("Mobile app is closed.");
            currentAnimationState = ANIM_ANGRY;
            // Force the display to the home screen to show the new face
            showHome = true;
            showMenu = showTimer = showStopwatch = showPomodoro = showSettings = showInfo = showBluetoothSettings = false;
            resetFaceAnimation();
        }
    }
};

class FocusModeCallbacks : public BLECharacteristicCallbacks {
    void onWrite(BLECharacteristic *pCharacteristic) {
        String value = pCharacteristic->getValue();
        value.trim();
        value.toUpperCase();

        bool requestedState = focusModeEnabled;
        if (value == "ON" || value == "1" || value == "TRUE") {
            requestedState = true;
        } else if (value == "OFF" || value == "0" || value == "FALSE") {
            requestedState = false;
        } else {
            Serial.print("Unknown focus mode command: ");
            Serial.println(value);
            return;
        }

        if (requestedState != focusModeEnabled) {
            focusModeEnabled = requestedState;
            preferences.putBool("focusMode", focusModeEnabled);
            Serial.print("Focus Mode set via BLE: ");
            Serial.println(focusModeEnabled ? "ON" : "OFF");

            if (showFocusModeSettings) {
                drawFocusModeSettings();
            }

            if (!focusModeEnabled) {
                currentAnimationState = ANIM_IDLE;
                resetFaceAnimation();
            }
        }
    }
};

class FaceControlCallbacks : public BLECharacteristicCallbacks {
    void onWrite(BLECharacteristic *pCharacteristic) {
        String value = pCharacteristic->getValue();
        Serial.print("Face Control Received: ");
        Serial.println(value);

        bool stateChanged = false;
        if (value == "IDLE") {
            currentAnimationState = ANIM_IDLE;
            stateChanged = true;
        } else if (value == "HAPPY") {
            currentAnimationState = ANIM_HAPPY;
            stateChanged = true;
        } else if (value == "SAD") {
            currentAnimationState = ANIM_SAD;
            stateChanged = true;
        } else if (value == "ANGRY") {
            currentAnimationState = ANIM_ANGRY;
            stateChanged = true;
        }

        if (stateChanged) {
            // Force the display to the home screen to show the new face
            showHome = true;
            showMenu = showTimer = showStopwatch = showPomodoro = showSettings = showInfo = showBluetoothSettings = false;
            resetFaceAnimation();
        }
    }
};

class CustomFaceSelectCallbacks : public BLECharacteristicCallbacks {
    void onWrite(BLECharacteristic *pCharacteristic) {
        String value = pCharacteristic->getValue();
        if (value.length() > 0) {
            customFaceToWrite = value;
            String filePath = "/" + customFaceToWrite + ".bin";

            // Close any previously opened file
            if (customFaceFile) {
                customFaceFile.close();
            }

            // Open the new file for writing
            customFaceFile = SPIFFS.open(filePath, FILE_WRITE);
            if (!customFaceFile) {
                Serial.println("Failed to open file for writing");
            }
        }
    }
};

class CustomFaceDataCallbacks : public BLECharacteristicCallbacks {
    void onWrite(BLECharacteristic *pCharacteristic) {
        size_t len = pCharacteristic->getLength();
        if (customFaceFile) {
            if (len > 0) {
                customFaceFile.write(pCharacteristic->getData(), len);
            } else {
                // Zero-length payload signifies end of transfer
                customFaceFile.close();
                Serial.println("Finished writing to file");
            }
        }
    }
};

